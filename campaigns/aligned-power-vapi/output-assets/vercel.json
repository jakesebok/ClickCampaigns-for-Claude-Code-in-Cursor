{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/gw?r=$1" },
    { "source": "/", "destination": "/portal/index.html" },
    { "source": "/assessment", "destination": "/html/vapi-landing.html" },
    { "source": "/assessment/start", "destination": "/html/vapi-quiz.html" },
    { "source": "/assessment/results", "destination": "/html/vapi-results.html" },
    { "source": "/portal/driver-library", "destination": "/portal/driver-library.html" },
    { "source": "/portal/archetype-library", "destination": "/portal/archetype-library.html" },
    { "source": "/login", "destination": "/portal/login.html" },
    { "source": "/signup", "destination": "/portal/signup.html" },
    { "source": "/confirm-email", "destination": "/portal/confirm.html" },
    { "source": "/check-email", "destination": "/portal/check-email.html" },
    { "source": "/dashboard", "destination": "/portal/dashboard.html" },
    { "source": "/settings", "destination": "/portal/settings.html" },
    { "source": "/settings/notifications", "destination": "/portal/notification-settings.html" },
    { "source": "/scorecard", "destination": "/portal/six-c-scorecard.html" },
    { "source": "/coach", "destination": "/portal/coach.html" },
    { "source": "/coach/client", "destination": "/portal/coach-client.html" },
    { "source": "/coach-dashboard", "destination": "/portal/coach-dashboard.html" },
    { "source": "/coach/client-detail", "destination": "/portal/coach-client-detail.html" },
    { "source": "/admin", "destination": "/portal/admin.html" },
    { "source": "/my-plan", "destination": "/portal/my-plan.html" },
    { "source": "/morning-checkin", "destination": "/portal/morning-checkin.html" },
    { "source": "/evening-review", "destination": "/portal/evening-review.html" },
    { "source": "/monthly-pulse", "destination": "/portal/monthly-pulse.html" },
    { "source": "/longitudinal", "destination": "/portal/longitudinal.html" },
    { "source": "/share/:hash", "destination": "/portal/share.html" },
    { "source": "/marketplace", "destination": "/portal/marketplace.html" },
    { "source": "/install", "destination": "/portal/install.html" }
  ],
  "redirects": [
    { "source": "/:path*", "has": [{ "type": "host", "value": "alignedpower.coach" }], "destination": "https://portal.alignedpower.coach/:path*", "permanent": true },
    { "source": "/:path*", "has": [{ "type": "host", "value": "www.alignedpower.coach" }], "destination": "https://portal.alignedpower.coach/:path*", "permanent": true },
    { "source": "/html/vapi-landing.html", "destination": "/assessment", "permanent": true },
    { "source": "/html/vapi-quiz.html", "destination": "/assessment/start", "permanent": true },
    { "source": "/html/vapi-results.html", "destination": "/assessment/results", "permanent": true },
    { "source": "/portal/driver-library.html", "destination": "/portal/driver-library", "permanent": true },
    { "source": "/portal/archetype-library.html", "destination": "/portal/archetype-library", "permanent": true },
    { "source": "/portal/login.html", "destination": "/login", "permanent": true },
    { "source": "/portal/signup.html", "destination": "/signup", "permanent": true },
    { "source": "/portal/confirm.html", "destination": "/confirm-email", "permanent": true },
    { "source": "/portal/check-email.html", "destination": "/check-email", "permanent": true },
    { "source": "/portal/dashboard.html", "destination": "/dashboard", "permanent": true },
    { "source": "/portal/settings.html", "destination": "/settings", "permanent": true },
    { "source": "/portal/six-c-scorecard.html", "destination": "/scorecard", "permanent": true },
    { "source": "/portal/coach.html", "destination": "/coach", "permanent": true },
    { "source": "/portal/coach-client.html", "destination": "/coach/client", "permanent": true },
    { "source": "/portal/coach-dashboard.html", "destination": "/coach-dashboard", "permanent": true },
    { "source": "/portal/admin.html", "destination": "/admin", "permanent": true },
    { "source": "/portal/my-plan.html", "destination": "/my-plan", "permanent": true },
    { "source": "/portal/morning-checkin.html", "destination": "/morning-checkin", "permanent": true },
    { "source": "/portal/evening-review.html", "destination": "/evening-review", "permanent": true },
    { "source": "/portal/monthly-pulse.html", "destination": "/monthly-pulse", "permanent": true },
    { "source": "/portal/longitudinal.html", "destination": "/longitudinal", "permanent": true }
  ],
  "crons": [
    { "path": "/api/cron/6c-reminders", "schedule": "5 15 * * *" },
    { "path": "/api/cron/6c-reminders", "schedule": "5 16 * * *" },
    { "path": "/api/cron/6c-reminders", "schedule": "5 17 * * *" },
    { "path": "/api/cron/ritual-reminders", "schedule": "*/15 * * * *" }
  ]
}
